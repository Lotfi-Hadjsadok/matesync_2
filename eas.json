{
  "cli": {
    "version": ">= 18.6.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "ANDROID_HOME": "/Users/user/Library/Android/sdk",
        "ANDROID_SDK_ROOT": "/Users/user/Library/Android/sdk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
        // "simulator": true
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "ANDROID_HOME": "/Users/user/Library/Android/sdk",
        "ANDROID_SDK_ROOT": "/Users/user/Library/Android/sdk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "ANDROID_HOME": "/Users/user/Library/Android/sdk",
        "ANDROID_SDK_ROOT": "/Users/user/Library/Android/sdk"
      }
    }
  },
  "submit": {
    "production": {}
  }
}